            "text": "[{\"id\":381,\"intakeId\":55,\"category\":\"architecture\",\"question\":\"Does this initiative introduce a new application or platform to the technology landscape?\",\"answer\":null,\"position\":0,\"createdAt\":\"2026-05-22T13:48:34.467Z\",\"updatedAt\":\"2026-05-22T13:48:34.467Z\"},{\"id\":382,\"intakeId\":55,\"category\":\"architecture\",\"question\":\"Does it integrate with existing enterprise systems (ERP, CRM, HRIS, data warehouse)?\",\"answer\":null,\"position\":1,\"createdAt\":\"2026-05-22T13:48:34.467Z\",\"updatedAt\":\"2026-05-22T13:48:34.467Z\"},{\"id\":383,\"intakeId\":55,\"category\":\"architecture\",\"question\":\"Will it require changes to the existing data model or master data?\",\"answer\":null,\"position\":2,\"createdAt\":\"2026-05-22T13:48:34.467Z\",\"updatedAt\":\"2026-05-22T13:48:34.467Z\"},{\"id\":384,\"intakeId\":55,\"category\":\"architecture\",\"question\":\"Does it use approved technologies from the enterprise reference architecture?\",\"answer\":null,\"position\":3,\"createdAt\":\"2026-05-22T13:48:34.467Z\",\"updatedAt\":\"2026-05-22T13:48:34.467Z\"},{\"id\":385,\"intakeId\":55,\"category\":\"architecture\",\"question\":\"Will it require new infrastructure (servers, network, storage, cloud accounts)?\",\"answer\":null,\"position\":4,\"createdAt\":\"2026-05-22T13:48:34.467Z\",\"updatedAt\":\"2026-05-22T13:48:34.467Z\"},{\"id\":386,\"intakeId\":55,\"category\":\"architecture\",\"question\":\"Are there dependencies on shared services (auth, logging, monitoring, API gateway)?\",\"answer\":null,\"position\":5,\"createdAt\":\"2026-05-22T13:48:34.467Z\",\"updatedAt\":\"2026-05-22T13:48:34.467Z\"},{\"id\":387,\"intakeId\":55,\"category\":\"architecture\",\"question\":\"Will it expose APIs that other systems will consume?\",\"answer\":null,\"position\":6,\"createdAt\":\"2026-05-22T13:48:34.467Z\",\"updatedAt\":\"2026-05-22T13:48:34.467Z\"},{\"id\":388,\"intakeId\":55,\"category\":\"architecture\",\"question\":\"Does the solution adhere to the organization's cloud and hosting standards?\",\"answer\":null,\"position\":7,\"createdAt\":\"2026-05-22T13:48:34.467Z\",\"updatedAt\":\"2026-05-22T13:48:34.467Z\"},{\"id\":389,\"intakeId\":55,\"category\":\"architecture\",\"question\":\"Has a high-level architecture diagram been produced and reviewed?\",\"answer\":null,\"position\":8,\"createdAt\":\"2026-05-22T13:48:34.467Z\",\"updatedAt\":\"2026-05-22T13:48:34.467Z\"},{\"id\":390,\"intakeId\":55,\"category\":\"architecture\",\"question\":\"Has the Architecture Review Board (ARB) been engaged?\",\"answer\":null,\"position\":9,\"createdAt\":\"2026-05-22T13:48:34.467Z\",\"updatedAt\":\"2026-05-22T13:48:34.467Z\"}]"
