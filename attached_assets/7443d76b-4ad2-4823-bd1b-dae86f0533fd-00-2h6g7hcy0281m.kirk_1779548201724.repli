            "mimeType": "application/json",
            "compression": 0,
            "text": "[{\"id\":391,\"intakeId\":55,\"category\":\"cybersecurity\",\"question\":\"Will this initiative process, store, or transmit personally identifiable information (PII)?\",\"answer\":null,\"position\":0,\"createdAt\":\"2026-05-22T13:48:34.630Z\",\"updatedAt\":\"2026-05-22T13:48:34.630Z\"},{\"id\":392,\"intakeId\":55,\"category\":\"cybersecurity\",\"question\":\"Will it process, store, or transmit payment card (PCI) or financial data?\",\"answer\":null,\"position\":1,\"createdAt\":\"2026-05-22T13:48:34.630Z\",\"updatedAt\":\"2026-05-22T13:48:34.630Z\"},{\"id\":393,\"intakeId\":55,\"category\":\"cybersecurity\",\"question\":\"Will it process, store, or transmit protected health information (PHI)?\",\"answer\":null,\"position\":2,\"createdAt\":\"2026-05-22T13:48:34.630Z\",\"updatedAt\":\"2026-05-22T13:48:34.630Z\"},{\"id\":394,\"intakeId\":55,\"category\":\"cybersecurity\",\"question\":\"Does it require user authentication and integrate with the corporate SSO / IdP?\",\"answer\":null,\"position\":3,\"createdAt\":\"2026-05-22T13:48:34.630Z\",\"updatedAt\":\"2026-05-22T13:48:34.630Z\"},{\"id\":395,\"intakeId\":55,\"category\":\"cybersecurity\",\"question\":\"Will it require role-based access control and segregation of duties?\",\"answer\":null,\"position\":4,\"createdAt\":\"2026-05-22T13:48:34.630Z\",\"updatedAt\":\"2026-05-22T13:48:34.630Z\"},{\"id\":396,\"intakeId\":55,\"category\":\"cybersecurity\",\"question\":\"Does it transmit data over the public internet, and if so is data encrypted in transit (TLS 1.2+)?\",\"answer\":null,\"position\":5,\"createdAt\":\"2026-05-22T13:48:34.630Z\",\"updatedAt\":\"2026-05-22T13:48:34.630Z\"},{\"id\":397,\"intakeId\":55,\"category\":\"cybersecurity\",\"question\":\"Is sensitive data encrypted at rest using approved key management?\",\"answer\":null,\"position\":6,\"createdAt\":\"2026-05-22T13:48:34.630Z\",\"updatedAt\":\"2026-05-22T13:48:34.630Z\"},{\"id\":398,\"intakeId\":55,\"category\":\"cybersecurity\",\"question\":\"Does it involve a third-party vendor or SaaS provider that requires a security assessment?\",\"answer\":null,\"position\":7,\"createdAt\":\"2026-05-22T13:48:34.630Z\",\"updatedAt\":\"2026-05-22T13:48:34.630Z\"},{\"id\":399,\"intakeId\":55,\"category\":\"cybersecurity\",\"question\":\"Have data classification, retention, and disposal requirements been documented?\",\"answer\":null,\"position\":8,\"createdAt\":\"2026-05-22T13:48:34.630Z\",\"updatedAt\":\"2026-05-22T13:48:34.630Z\"},{\"id\":400,\"intakeId\":55,\"category\":\"cybersecurity\",\"question\":\"Has a threat model / security risk assessment been completed for this initiative?\",\"answer\":null,\"position\":9,\"createdAt\":\"2026-05-22T13:48:34.630Z\",\"updatedAt\":\"2026-05-22T13:48:34.630Z\"}]"
